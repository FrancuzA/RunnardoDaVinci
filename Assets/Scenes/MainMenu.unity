  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>REGULAMIN</b>\r\n1.O\u015Bwiadczam, \u017Ce zapozna\u0142em/-am si\u0119
    z Regulaminem Konkursu i spe\u0142niam warunki uczestnictwa okre\u015Blone w
    Regulaminie.  \r\n<b>ZGODY MARKETINGOWE</b>\r\n1.Wyra\u017Cam zgod\u0119 na przetwarzanie
    moich danych osobowych, w tym mojego wizerunku.\r\n2.Wyra\u017Cam zgod\u0119
    na otrzymywanie od Collegium Da Vinci informacji marketingowych za po\u015Brednictwem
    poczty elektronicznej. \r\n3.Wyra\u017Cam zgod\u0119 na otrzymywanie od Collegium
    Da Vinci informacji marketingowych za po\u015Brednictwem SMS/MMS.\r\n4.Wyra\u017Cam
    zgod\u0119 na otrzymywanie od Collegium Da Vinci informacji marketingowych za
    po\u015Brednictwem po\u0142\u0105cze\u0144 telefonicznych.\r\nAdministratorem
    danych osobowych jest Collegium Da Vinci z siedzib\u0105 przy ul. gen. T. Kutrzeby
    10, 61-719 Pozna\u0144. Klauzula informacyjna dotycz\u0105c\u0105 przetwarzania
    danych osobowych znajduje si\u0119 tutaj. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
